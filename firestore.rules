rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
       return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Global deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Schedule Rules
    match /schedules/{scheduleId} {
      allow create: if isSignedIn() 
        && isValidId(scheduleId)
        && incoming().userId == request.auth.uid
        && isValidSchedule(incoming());
      
      allow update: if isSignedIn() 
        && isOwner(existing().userId)
        && incoming().userId == existing().userId
        && isValidSchedule(incoming());
        
      allow delete: if isSignedIn() 
        && isOwner(existing().userId);

      allow list: if isSignedIn() 
        && resource.data.userId == request.auth.uid;
        
      allow get: if isSignedIn() 
        && isOwner(resource.data.userId);

      function isValidSchedule(data) {
        return data.title is string && data.title.size() <= 200
          && data.date is string && data.date.size() <= 20
          && data.startTime is string && data.startTime.size() <= 10
          && data.endTime is string && data.endTime.size() <= 10
          && data.priority in ['Low', 'Medium', 'High']
          && data.category in ['Work', 'Personal', 'Health', 'Education', 'Other']
          && data.status in ['Pending', 'In Progress', 'Completed', 'Cancelled']
          && data.subtasks is list
          && data.userId == request.auth.uid;
      }
    }
  }
}
